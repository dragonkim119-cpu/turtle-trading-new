# 이 파일을 .env로 복사해서 값 채우고 사용
# cp .env.example .env

# 텔레그램 봇 알림 (미설정 시 알림 생략, 신호는 DB에 그대로 기록됨)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 웹 대시보드 로그인 비밀번호 (미설정 시 인증 없음 — 로컬 전용으로만 사용)
WEB_PASSWORD=

# SQLite DB 경로 — 값 채우지 않으려면 이 줄을 통째로 지울 것
# (빈 문자열로 두면 `??` 기본값 fallback이 안 걸려 SQLite가 임시 DB로 열림 — data/turtle.db와 분리됨)
# DB_PATH=
